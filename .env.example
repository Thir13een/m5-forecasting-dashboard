# Copy this file to .env and fill in your values
# cp .env.example .env

# LightGBM model directory (inside the container)
MODEL_DIR=/app/data/models
DATA_DIR=/app/data/models

# Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# PostgreSQL connection (matches docker-compose.yml)
DATABASE_URL=postgresql://m5:m5pass@postgres:5432/m5db

# Allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:3000

# Absolute path to your local LightGBM model directory
MODELS_PATH=/path/to/your/models
